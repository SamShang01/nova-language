struct Vector {
    x: float,
    y: float,
    
    func new(x: float, y: float) -> Vector {
        self.x = x;
        self.y = y;
        return self;
    }
    
    func __add__(other: Vector) -> Vector {
        return Vector.new(self.x + other.x, self.y + other.y);
    }
    
    func __sub__(other: Vector) -> Vector {
        return Vector.new(self.x - other.x, self.y - other.y);
    }
    
    func __mul__(scalar: float) -> Vector {
        return Vector.new(self.x * scalar, self.y * scalar);
    }
    
    func __div__(scalar: float) -> Vector {
        return Vector.new(self.x / scalar, self.y / scalar);
    }
    
    func length() -> float {
        return sqrt(self.x * self.x + self.y * self.y);
    }
}

func main() {
    let v1 = Vector.new(1.0, 2.0);
    let v2 = Vector.new(3.0, 4.0);
    
    let v3 = v1 + v2;
    let v4 = v1 - v2;
    let v5 = v1 * 2.0;
    let v6 = v1 / 2.0;
    
    print("v1: (" + str(v1.x) + ", " + str(v1.y) + ")");
    print("v2: (" + str(v2.x) + ", " + str(v2.y) + ")");
    print("v1 + v2: (" + str(v3.x) + ", " + str(v3.y) + ")");
    print("v1 - v2: (" + str(v4.x) + ", " + str(v4.y) + ")");
    print("v1 * 2: (" + str(v5.x) + ", " + str(v5.y) + ")");
    print("v1 / 2: (" + str(v6.x) + ", " + str(v6.y) + ")");
    print("v1 length: " + str(v1.length()));
}

main();