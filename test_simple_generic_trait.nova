// 简单的泛型 Trait 测试
// 测试泛型 Trait 定义和 Impl 块，不涉及数组操作

trait Comparable<T> {
    func compareTo(other: T) -> int;
}

struct Point {
    x: int;
    y: int;
}

// 为 Point 实现 Comparable Trait
impl Comparable<Point> for Point {
    func compareTo(other: Point) -> int {
        var thisSum = this.x + this.y;
        var otherSum = other.x + other.y;
        if thisSum > otherSum {
            return 1;
        } else if thisSum < otherSum {
            return -1;
        } else {
            return 0;
        }
    }
}

func main() {
    var p1 = Point();
    p1.x = 10;
    p1.y = 20;
    var p2 = Point();
    p2.x = 15;
    p2.y = 15;
    var p3 = Point();
    p3.x = 5;
    p3.y = 25;
    
    print("Testing Comparable Trait:");
    print("p1.compareTo(p2) = " + str(p1.compareTo(p2))); // 应该返回 0
    print("p1.compareTo(p3) = " + str(p1.compareTo(p3))); // 应该返回 -1
    print("p3.compareTo(p2) = " + str(p3.compareTo(p2))); // 应该返回 1
    
    print("Test passed!");
}