// 测试基本的整数比较

struct Point {
    x: int;
    y: int;
}

impl Point {
    func compareTo(other: Point) -> int {
        var thisSum = this.x + this.y;
        var otherSum = other.x + other.y;
        if thisSum > otherSum {
            return 1;
        } else if thisSum < otherSum {
            return -1;
        } else {
            return 0;
        }
    }
}

func main() {
    var p1 = Point();
    p1.x = 10;
    p1.y = 20;
    var p2 = Point();
    p2.x = 15;
    p2.y = 15;
    
    print("Testing Point comparison:");
    print("p1.compareTo(p2) = " + str(p1.compareTo(p2)));
    
    print("Test passed!");
}
