// 测试泛型类实例化
template class Pair<P,Q>{
    var p:P;
    var q:Q;
}

func main() {
    print("=== Test Generic Class ===");
    
    // 测试1: 两个整数
    let pair1 = Pair(12, 12);
    print("Pair(12, 12) created successfully");
    
    // 测试2: 整数和字符串
    let pair2 = Pair(42, "hello");
    print("Pair(42, hello) created successfully");
    
    // 测试3: 字符串和浮点数
    let pair3 = Pair("test", 3.14);
    print("Pair(test, 3.14) created successfully");
    
    print("\n=== All Tests Passed! ===");
}

main();
