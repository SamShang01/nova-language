// 测试Nova语言VS Code插件

// 变量声明
let message: string = "Hello, Nova!";
let count: int = 42;
let pi: float = 3.14;

// 函数定义
func greet(name: string) -> string {
    return "Hello, " + name + "!";
}

// 结构体定义
struct Person {
    name: string;
    age: int;
}

// 条件语句
if count > 0 {
    print(greet("World"));
} else {
    print("No count");
}

// 循环语句
for i in 0..5 {
    print("Count: " + i);
}

// 调用函数
print(message);
print("Count: " + count);
print("Pi: " + pi);