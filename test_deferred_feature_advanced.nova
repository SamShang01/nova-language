// 测试延迟运算特性（高级功能）

// 启用延迟运算特性
feature DeferredOperations;

func main() {
    // 测试基本延迟运算
    let a = 1 / 3 * 3;
    print("1/3*3 = ");
    print(str(a));
    
    // 测试高级延迟运算
    let b = 1 / 3 * 2 * 3;
    print("1/3*2*3 = ");
    print(str(b));
    
    // 测试更复杂的延迟运算
    let c = 2 / 5 * 3 * 5;
    print("2/5*3*5 = ");
    print(str(c));
}
