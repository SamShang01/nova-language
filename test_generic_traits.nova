// 泛型 Trait 测试用例

// 1. 泛型 Trait 定义
trait Iterator<T> {
    func next(self: Iterator<T>) -> T;
    func has_next(self: Iterator<T>) -> bool;
}

// 2. 泛型结构体
struct List<T> {
    items: [T];
    index: int;
}

// 3. 泛型 Impl 块
impl<T> Iterator<T> for List<T> {
    func next(self: List<T>) -> T {
        if self.has_next() {
            let item = self.items[self.index];
            self.index = self.index + 1;
            return item;
        } else {
            return nil;
        }
    }
    
    func has_next(self: List<T>) -> bool {
        return self.index < len(self.items);
    }
}

// 4. 使用泛型 Trait 的函数
generic func iterate<T>(iter: Iterator<T>) {
    while iter.has_next() {
        let item = iter.next();
        print(item);
    }
}

// 5. 多个泛型 Trait
trait Comparable<T> {
    func compare(self: T, other: T) -> int;
}

trait Cloneable<T> {
    func clone(self: T) -> T;
}

// 6. 为基本类型实现泛型 Trait
impl Comparable<int> for int {
    func compare(self: int, other: int) -> int {
        if self < other {
            return -1;
        } else if self > other {
            return 1;
        } else {
            return 0;
        }
    }
}

impl Cloneable<int> for int {
    func clone(self: int) -> int {
        return self;
    }
}

// 7. 泛型函数使用多个 Trait 约束
generic func process<T>(value: T)
    where T: Comparable<T> + Cloneable<T>
{
    let cloned = value.clone();
    print(cloned);
}

func main() {
    // 测试泛型 Trait
    let list = List<int>(items: [1, 2, 3, 4, 5], index: 0);
    
    print("Iterating over list:");
    iterate(list);
    
    // 测试多个 Trait 约束
    let x = 42;
    print("Processing value:");
    process(x);
    
    print("Generic trait tests passed!");
}
