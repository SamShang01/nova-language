// 测试double类型功能

// 声明double类型变量
let a = 3.14159265358979323846;
let b = 2.71828182845904523536;

// 测试加法
let sum = a + b;
print("a + b = " + str(sum));

// 测试减法
let diff = a - b;
print("a - b = " + str(diff));

// 测试乘法
let product = a * b;
print("a * b = " + str(product));

// 测试除法
let quotient = a / b;
print("a / b = " + str(quotient));

// 测试比较
let greater = a > b;
print("a > b = " + str(greater));

let equal = a == a;
print("a == a = " + str(equal));

print("测试完成");
