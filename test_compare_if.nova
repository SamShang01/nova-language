// 测试模板函数中if语句的比较操作符

template func myMin<T>(a: T, b: T): T {
    if a < b {
        return a;
    }
    return b;
}

func main() {
    print("=== Test If Comparison ===");
    
    let result = myMin<int>(10, 20);
    print("myMin(10, 20) = ");
    print(result);
    
    let result2 = myMin<int>(30, 20);
    print("myMin(30, 20) = ");
    print(result2);
    
    print("=== Done ===");
}

main();
