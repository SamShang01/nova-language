{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Nova",
  "scopeName": "source.nova",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#types"
    },
    {
      "include": "#variables"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.nova",
          "match": "//.*$"
        },
        {
          "name": "comment.block.nova",
          "begin": "/\*",
          "end": "\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.nova",
          "begin": "\"",
          "end": "\"",
          "escapes": "\\."
        },
        {
          "name": "string.quoted.single.nova",
          "begin": "'",
          "end": "'",
          "escapes": "\\."
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.nova",
          "match": "\\b\\d+\\b"
        },
        {
          "name": "constant.numeric.float.nova",
          "match": "\\b\\d+\\.\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.nova",
          "match": "\\b(func|struct|class|if|else|while|for|switch|case|default|return|let|var|const|import|from|as|export|module|public|private|protected|static|async|await)\\b"
        },
        {
          "name": "keyword.operator.logical.nova",
          "match": "\\b(and|or|not|true|false|null)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.nova",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.assignment.nova",
          "match": "[=+\\-*/%]="
        },
        {
          "name": "keyword.operator.comparison.nova",
          "match": "[!=]=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.nova",
          "match": "&&|\\|\\|"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.nova",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\s*\\("
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.nova",
          "match": "\\b(int|float|bool|string|void|any|List|Dict|Set|Tuple)\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.nova",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}