// 测试type类型和类型萃取

// 类型容器
template class Type<T> {
    var type_value: type: T;
}

// 移除指针
template class RemovePointer<T> {
    var type_value: type: T;
}

// 添加指针
template class AddPointer<T> {
    var type_value: type: T;
}

func main() {
    print("=== Test Type Type ===");
    
    // 测试1: 类型作为值
    // Type<int> 表示一个包含int类型的容器
    let int_type: type: int = type: int;
    print("type: int created successfully");
    
    // 测试2: 指针类型
    let ptr_type: type: *int = type: *int;
    print("type: *int created successfully");
    
    // 测试3: 数组类型
    let arr_type: type: [int] = type: [int];
    print("type: [int] created successfully");
    
    print("\n=== All Tests Passed! ===");
}

main();
