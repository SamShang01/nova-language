// 测试延迟运算特性（扩展功能）

// 启用延迟运算特性
feature DeferredOperations;

func main() {
    // 测试基本延迟运算
    let a = 1 / 3 * 3;
    print("1/3*3 = ");
    print(str(a));  // 应输出: 1.0
    
    // 测试高级延迟运算
    let b = 1 / 3 * 2 * 3;
    print("1/3*2*3 = ");
    print(str(b));  // 应输出: 2.0
    
    // 测试加减法抵消
    let c = 0.1 + 0.2 - 0.2;
    print("0.1+0.2-0.2 = ");
    print(str(c));  // 应输出: 0.1
    
    // 测试复杂加减法抵消
    let d = 0.1 + 0.2 - 1.0 - 0.2;
    print("0.1+0.2-1.0-0.2 = ");
    print(str(d));  // 应输出: -0.9
    
    // 测试更复杂的混合运算
    let e = 1.0 / 2.0 * 4.0 + 0.1 + 0.2 - 0.2;
    print("1.0/2.0*4.0+0.1+0.2-0.2 = ");
    print(str(e));  // 应输出: 2.1
}
