// 测试double类型功能

// 声明double类型变量
let a: double = 3.14159265358979323846;
let b: double = 2.71828182845904523536;

// 测试加法
let sum: double = a + b;
print("a + b = " + str(sum));

// 测试减法
let diff: double = a - b;
print("a - b = " + str(diff));

// 测试乘法
let product: double = a * b;
print("a * b = " + str(product));

// 测试除法
let quotient: double = a / b;
print("a / b = " + str(quotient));

// 测试比较
let greater: bool = a > b;
print("a > b = " + str(greater));

let equal: bool = a == a;
print("a == a = " + str(equal));

// 测试float类型仍然使用Python的float
let f: float = 3.14;
print("float value = " + str(f));

print("测试完成");
