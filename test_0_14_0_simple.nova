// 简单测试 0.14.0 基本功能

func main() {
    print("=== Nova 0.14.0 简单测试 ===");
    print("");
    
    // 测试 1: 基本数值算法
    print("【测试 1】数值算法");
    var sum = 0;
    var i = 1;
    while i <= 10 {
        sum = sum + i;
        i = i + 1;
    }
    print("1 到 10 的累加和:");
    print(sum);
    print("");
    
    // 测试 2: 阶乘计算
    print("【测试 2】阶乘计算");
    var n = 5;
    var fact = 1;
    var j = 1;
    while j <= n {
        fact = fact * j;
        j = j + 1;
    }
    print("5 的阶乘:");
    print(fact);
    print("");
    
    // 测试 3: 斐波那契数列
    print("【测试 3】斐波那契数列");
    var a = 0;
    var b = 1;
    var count = 0;
    print("前 10 个斐波那契数:");
    while count < 10 {
        print(a);
        var temp = a + b;
        a = b;
        b = temp;
        count = count + 1;
    }
    print("");
    
    print("=== 所有测试完成 ===");
}
